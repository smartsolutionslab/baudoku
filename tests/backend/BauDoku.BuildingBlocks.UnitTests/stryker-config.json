{
  "stryker-config": {
    "solution": "../../../src/backend/BauDoku.slnx",
    "mutation-level": "Standard",
    "reporters": ["html", "json", "progress", "cleartext"],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "!**/obj/**",
      "!**/bin/**",
      "!**/Migrations/**"
    ],
    "ignore-mutations": ["string"],
    "concurrency": 2
  }
}
